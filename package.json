{
  "name": "opencode-subagents-monitor",
  "version": "0.1.2",
  "description": "OpenCode TUI plugin that shows the number of running subagents in the sidebar footer",
  "type": "module",
  "license": "MIT",
  "author": "darianstlex",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darianstlex/opencode-subagents-monitor.git"
  },
  "homepage": "https://github.com/darianstlex/opencode-subagents-monitor#readme",
  "bugs": {
    "url": "https://github.com/darianstlex/opencode-subagents-monitor/issues"
  },
  "keywords": [
    "opencode",
    "plugin",
    "tui",
    "subagent",
    "sidebar"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "opencode-subagents-monitor": "bin/install.mjs"
  },
  "files": [
    "src",
    "bin"
  ],
  "exports": {
    "./tui": {
      "types": "./src/index.tsx",
      "import": "./src/index.tsx"
    }
  },
  "oc-plugin": [
    "tui"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "release": "./scripts/release.sh"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0",
    "@opentui/solid": ">=0.3.0",
    "solid-js": ">=1.8.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.16.2",
    "@opentui/solid": "^0.3.2",
    "solid-js": "^1.9.13",
    "typescript": "^6.0.3",
    "bun-types": "^1.3.14"
  }
}
