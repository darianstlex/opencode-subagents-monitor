{
  "name": "opencode-subagents-monitor",
  "version": "0.1.7",
  "description": "OpenCode TUI plugin that shows the number of running subagents in the sidebar footer",
  "type": "module",
  "license": "MIT",
  "author": "darianstlex",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/darianstlex/opencode-subagents-monitor.git"
  },
  "homepage": "https://github.com/darianstlex/opencode-subagents-monitor#readme",
  "bugs": {
    "url": "https://github.com/darianstlex/opencode-subagents-monitor/issues"
  },
  "keywords": [
    "opencode",
    "plugin",
    "tui",
    "subagent",
    "sidebar"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "opencode-subagents-monitor": "bin/install.mjs"
  },
  "files": [
    "src",
    "bin"
  ],
  "exports": {
    "./tui": {
      "types": "./src/index.tsx",
      "import": "./src/entry.mjs"
    }
  },
  "oc-plugin": [
    "tui"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": false
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build:tui": "node scripts/build-tui.mjs",
    "prepublishOnly": "npm run build:tui",
    "release": "./scripts/release.sh"
  },
  "dependencies": {
    "@opentui/core": "^0.4.2",
    "@opentui/solid": "^0.4.2",
    "solid-js": "1.9.12"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.17.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@opencode-ai/plugin": "^1.17.3",
    "@opentui/solid": "^0.4.2",
    "@types/node": "^25.9.3",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-solid": "^1.9.12",
    "solid-js": "1.9.12",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
}
